# ============================================================
# Copy this file to ".env.local" for local testing with
# `vercel dev`. In production, add EVERY one of these in:
# Vercel Dashboard -> your project -> Settings -> Environment Variables
# ============================================================

# --- Twilio (WhatsApp) ---
# Get these from https://console.twilio.com  (Account Info panel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The WhatsApp-enabled Twilio number, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:

# --- Supabase ---
# Get these from https://app.supabase.com -> your project -> Settings -> API
SUPABASE_URL=
# Use the SERVICE ROLE key (not the anon key) since this runs server-side only.
# Never expose this key in any frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# --- Yellow Card ---
# Get these from your Yellow Card dashboard once your integration is approved:
# https://docs.yellowcard.engineering
YELLOWCARD_API_KEY=
YELLOWCARD_SECRET_KEY=
# Sandbox first, then swap to the production URL Yellow Card gives you.
YELLOWCARD_BASE_URL=https://sandbox.api.yellowcard.io

# --- App ---
# The public HTTPS URL Vercel gives your deployment, e.g. https://your-app.vercel.app
PUBLIC_APP_URL=
